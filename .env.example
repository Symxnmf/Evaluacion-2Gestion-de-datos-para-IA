# Example environment variables for Supabase / Postgres connection
# Option A (recommended): full Postgres connection string (SQLAlchemy compatible)
# Get this from Supabase project settings -> Database -> Connection string
DATABASE_URL=postgres://user:password@dbhost:5432/database_name

# Option B: Supabase client (optional - not used by default loader)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_or_service_role_key

# Local fallback path for sqlite (used when DATABASE_URL is not set)
LOCAL_SQLITE_DB=data/db/titanic.db

# Usage:
# 1) Copy this file to .env and fill the values.
# 2) Install deps: pip install -r requirements.txt
# 3) Run: python src/load.py
